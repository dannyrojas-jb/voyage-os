# Copy to .env.local and fill in. Never commit real keys.

# From Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# From console.anthropic.com > API Keys. Server-side only, never exposed to the browser.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Your deployed URL (used to build client-portal links). Locally: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
